{
  "name": "@jflamb/fdic-ds-tokens",
  "version": "0.1.1",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "scripts": {
    "build": "node ../../scripts/tokens/generate-dtcg.mjs",
    "validate": "node ../../scripts/tokens/generate-dtcg.mjs --check && node ../../scripts/validate-package-surfaces.mjs"
  },
  "sideEffects": [
    "*.css"
  ],
  "exports": {
