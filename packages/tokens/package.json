    "./fdic.tokens.json": "./fdic.tokens.json",
    "./interaction.css": "./interaction.css",
    "./semantic.css": "./semantic.css"
  },
  "files": [
    "styles.css",
    "fdic.tokens.json",
    "interaction.css",
    "semantic.css"
  ]
}
