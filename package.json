{
  "name": "fdic-design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "sync:components": "node scripts/components/sync.mjs",
    "validate:components": "node scripts/components/validate.mjs",
    "new:component": "node scripts/components/scaffold.mjs",
    "generate:icon-masks": "node scripts/icons/generate-icon-masks.mjs",
    "validate:icon-masks": "node scripts/icons/validate-icon-masks.mjs",
    "build": "npm run build:components && npm run generate:icon-masks && npm run build:react && npm run build:docs",
    "dev:docs": "npm run docs:dev --workspace @fdic-ds/docs",
    "dev:storybook": "npm run storybook --workspace @fdic-ds/storybook",
    "build:docs": "npm run build --workspace @fdic-ds/docs",
    "build:storybook": "npm run build --workspace @fdic-ds/storybook",
    "build:components": "npm run build --workspace @fdic-ds/components",
    "build:react": "npm run build --workspace @fdic-ds/react",
    "test:components": "npm run test --workspace @fdic-ds/components",
    "test:storybook": "npm run test --workspace @fdic-ds/storybook",
    "dev-server:start": "node scripts/dev/local-dev-servers.mjs start",
    "dev-server:stop": "node scripts/dev/local-dev-servers.mjs stop",
    "dev-server:status": "node scripts/dev/local-dev-servers.mjs status",
    "dev-server:url": "node scripts/dev/local-dev-servers.mjs url"
  },
  "overrides": {
    "vite": "8.0.7"
  }
}
