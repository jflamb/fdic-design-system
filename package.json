{
  "name": "fdic-design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "browserslist": [
    "Chrome >= 123",
    "Edge >= 123",
    "Firefox >= 128",
    "Safari >= 17.5",
    "iOS >= 17.5"
  ],
  "scripts": {
    "sync:components": "node scripts/components/sync.mjs",
    "validate:components": "node scripts/components/validate.mjs",
    "validate:tokens": "npm run validate --workspace @jflamb/fdic-ds-tokens",
    "validate:packages": "node scripts/validate-package-surfaces.mjs && node scripts/validate-doc-contracts.mjs && node scripts/validate-downstream-reference.mjs && node scripts/validate-storybook-a11y.mjs",
    "validate:docs-contrast": "node scripts/validate-docs-contrast.mjs",
    "validate:react": "npm run build --workspace @fdic-ds/react && node scripts/validate-react-package.mjs",
    "validate:release": "npm run validate:packages && npm run validate:components && npm run test:components && npm run test:storybook && npm run validate:docs-contrast && npm run validate:react && npm run build",
    "new:component": "node scripts/components/scaffold.mjs",
    "build:tokens": "npm run build --workspace @jflamb/fdic-ds-tokens",
    "generate:icon-masks": "node scripts/icons/generate-icon-masks.mjs",
    "validate:icon-masks": "node scripts/icons/validate-icon-masks.mjs",
    "build": "npm run build:tokens && npm run build:components && npm run generate:icon-masks && npm run build:react && npm run build:docs",
    "dev:docs": "npm run docs:dev --workspace @fdic-ds/docs",
    "dev:storybook": "npm run storybook --workspace @fdic-ds/storybook",
    "build:docs": "npm run build --workspace @fdic-ds/docs",
    "build:storybook": "npm run build --workspace @fdic-ds/storybook",
    "build:components": "npm run build --workspace @jflamb/fdic-ds-components",
    "build:react": "npm run build --workspace @fdic-ds/react",
    "test:components": "npm run test --workspace @jflamb/fdic-ds-components",
    "test:storybook": "npm run test --workspace @fdic-ds/storybook",
    "dev-server:start": "node scripts/dev/local-dev-servers.mjs start",
    "dev-server:stop": "node scripts/dev/local-dev-servers.mjs stop",
    "dev-server:status": "node scripts/dev/local-dev-servers.mjs status",
    "dev-server:url": "node scripts/dev/local-dev-servers.mjs url"
  }
}
