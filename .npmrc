# Publish FDIC Design System packages from GitHub Packages.
@jflamb:registry=https://npm.pkg.github.com

# Do not commit a real token here.
#
# Local development:
#   npm login --scope=@jflamb --registry=https://npm.pkg.github.com --auth-type=legacy
#
# CI publishing/installing:
#   echo "//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}" >> .npmrc
#
# Required token scopes:
#   - read:packages for installing
#   - write:packages for publishing
#   - repo if packages inherit permissions from a private repository
